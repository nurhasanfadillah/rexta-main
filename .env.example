# Supabase Configuration
# Copy file ini ke .env.local untuk development lokal
# Set variabel ini di Vercel Project Settings → Environment Variables untuk production

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

